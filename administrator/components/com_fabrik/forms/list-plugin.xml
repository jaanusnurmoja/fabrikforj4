<form addfieldprefix="Fabrik\Component\Fabrik\Administrator\Field" >
	<name>List Plugin General Options</name>
	<fieldset name="plugins">

		<field name="plugin_state"
		       type="radio"
		       class="btn-group"
		       default="1"
			layout="joomla.form.field.radio.switcher"
		       label="COM_FABRIK_PUBLISHED"
		       repeat="true">
			<option value="0">JNO</option>
			<option value="1">JYES</option>
		</field>

		<field name="plugins"
		       type="pluginlist"
		       plugin="fabrik_list"
		       class="inputbox elementtype"
		       label="COM_FABRIK_SELECT_DO"
		       repeat="true"
		       required="true"/>

		<field name="plugin_description"
		       type="text"
		       repeat="true"
		       label="COM_FABRIK_PLUGIN_DESCRIPTION_LABEL"
		       description="COM_FABRIK_PLUGIN_DESCRIPTION_DESC"/>

	</fieldset>

</form>
