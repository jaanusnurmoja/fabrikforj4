    <menu img="class:default">Fabrik</menu>
    <submenu>
      <menu alt="Home" img="../administrator/components/com_fabrik/images/fabrik.png" link="option=com_fabrik&amp;view=home">Home</menu>
      <menu alt="Lists" img="../administrator/components/com_fabrik/images/lists.png" link="option=com_fabrik&amp;view=lists">Lists</menu>
      <menu alt="Forms" img="../administrator/components/com_fabrik/images/forms.png" link="option=com_fabrik&amp;view=forms">Forms</menu>
