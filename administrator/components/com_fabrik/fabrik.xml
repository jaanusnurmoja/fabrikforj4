  <version>0.1.0</version>
  <description>COM_FABRIK_XML_DESCRIPTION</description>
  <namespace path="src">Fabrikar\Component\Fabrik</namespace>
  <scriptfile>script.com_fabrik.php</scriptfile>
  <files folder="site">
    <folder>language</folder>
    <folder>layouts</folder>
    <folder>libs</folder>
    <folder>src</folder>
    <folder>tmpl</folder>
  </files>
  <media folder="media/fabrikar/com_fabrik" destination="fabrikar/com_fabrik">
    <folder>js</folder>
    <folder>css</folder>
    <file>joomla.asset.json</file>
